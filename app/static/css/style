.team-section{
text-align:center;
padding:60px 20px;
}

.team-container{
display:flex;
justify-content:center;
gap:30px;
flex-wrap:wrap;
margin-top:40px;
}

.team-card{
background:rgba(0,100,50,0.7);
backdrop-filter:blur(10px);
padding:25px;
border-radius:15px;
width:250px;
color:white;
box-shadow:0 10px 25px rgba(0,0,0,0.3);
}

.team-card h3{
color:#9fff9f;
}
